# Copy this file to .env and replace every change-me value before deployment.
HOMETRAP_SECRET_KEY=change-me-to-a-long-random-value
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
HOMETRAP_PORT=8000
# Exact Docker gateway/proxy address, for example 172.18.0.1/32. Leave empty
# until Synology reverse proxy is configured; never use 0.0.0.0/0.
HOMETRAP_TRUSTED_PROXY_CIDRS=
